# ─────────────────────────────────────────────────────────
#  Smart Expense Tracker — Backend Environment Config
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
# Local SQLite (default — no setup needed)
DATABASE_URL=sqlite:///./expense_tracker.db

# Production PostgreSQL via Supabase (uncomment when deploying)
# DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── Security ─────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-use-a-strong-random-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI Features (optional) ───────────────────────────────
# Get free Groq key from: https://console.groq.com/
GROQ_API_KEY=
LLM_PROVIDER=groq

# Google Gemini (optional)
GEMINI_API_KEY=

# ── Google OAuth (optional — for future Google Sign-In) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Frontend URL ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
